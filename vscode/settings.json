{
    "claudeCode.preferredLocation": "panel",
    "claudeCode.useTerminal": true,
    "cSpell.blockCheckingWhenLineLengthGreaterThan": 20000,
    "cSpell.blockCheckingWhenTextChunkSizeGreaterThan": 1000,
    "cSpell.diagnosticLevel": "Warning",
    "cSpell.spellCheckOnlyWorkspaceFiles": true,
    "cSpell.userWords": [
        "Anurag",
        "anuragdevanapally",
        "Cowork",
        "Devanapally",
        "frontmatter",
        "mwba",
        "nohup",
        "platformer",
        "rgba",
        "stddev",
        "Superellipse",
        "webbrowser",
        "webp"
    ],
    "[dart]": {
        "editor.defaultFormatter": "Dart-Code.dart-code",
        "editor.formatOnSave": true,
        "editor.formatOnType": true,
        "editor.inlayHints.enabled": "offUnlessPressed",
        "editor.rulers": [
            100
        ],
        "editor.suggest.insertMode": "replace",
        "editor.tabCompletion": "onlySnippets",
        "editor.wordBasedSuggestions": "currentDocument"
    },
    "dart.cliConsole": "terminal",
    "dart.closingLabelsTextStyle": "italic",
    "dart.debugExternalPackageLibraries": true,
    "dart.debugSdkLibraries": true,
    "dart.flutterHotReloadOnSave": "manualIfDirty",
    "dart.flutterSelectDeviceWhenConnected": false,
    "dart.previewFlutterUiGuides": true,
    "dart.promptToGetPackages": false,
    "dart.renameFilesWithClasses": "always",
    "dart.runPubGetOnPubspecChanges": "never",
    "dart.showTodos": true,
    "debug.internalConsoleOptions": "openOnSessionStart",
    "debug.toolBarLocation": "commandCenter",
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.guides.bracketPairs": "active",
    "editor.hover.delay": 1000,
    "editor.minimap.showRegionSectionHeaders": true,
    "editor.minimap.showSlider": "always",
    "editor.renderWhitespace": "all",
    "editor.unusualLineTerminators": "prompt",
    "editor.wordWrap": "on",
    "explorer.autoReveal": true,
    "explorer.openEditors.sortOrder": "alphabetical",
    "explorer.openEditors.visible": 100,
    "files.exclude": {
        "**/.git": false
    },
    "git.autorefresh": false,
    "git.autoRepositoryDetection": false,
    // Setting this to false allows us to use Gitlens blame info instead.
    "git.blame.editorDecoration.enabled": false,
    "git.blame.statusBarItem.enabled": false,
    "git.enableStatusBarSync": false,
    "git.openRepositoryInParentFolders": "never",
    "git.optimisticUpdate": false,
    "git.pullTags": false,
    "github.branchProtection": false,
    "gitlens.advanced.messages": {
        "suppressGitDisabledWarning": true,
        "suppressGitMissingWarning": true
    },
    "gitlens.ai.enabled": false,
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "gitlens.gitkraken.mcp.autoEnabled": false,
    "go.toolsManagement.autoUpdate": true,
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features",
        "editor.quickSuggestions": {
            "strings": true
        },
        "editor.suggest.insertMode": "replace"
    },
    "[markdown]": {
        "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
    },
    "markdown.occurrencesHighlight.enabled": true,
    "markdownlint.configFile": "~/.markdownlint.yml",
    "redhat.telemetry.enabled": false,
    "references.preferredLocation": "view",
    "search.showLineNumbers": true,
    "security.workspace.trust.untrustedFiles": "newWindow",
    "testing.automaticallyOpenPeekView": "failureAnywhere",
    "window.autoDetectColorScheme": true,
    "window.commandCenter": true,
    "window.openFoldersInNewWindow": "on",
    "window.title": "${rootName}${separator}${profileName}${separator}${activeEditorShort}",
    "window.zoomLevel": 1.5,
    "workbench.activityBar.compact": true,
    "workbench.colorTheme": "Monokai Pro (Filter Spectrum)",
    "workbench.editor.enablePreview": false,
    "workbench.editor.limit.value": 100,
    "workbench.editor.showTabs": "none",
    "workbench.editor.titleScrollbarSizing": "large",
    "workbench.iconTheme": "Monokai Pro (Filter Spectrum) Icons",
    "workbench.preferredDarkColorTheme": "Monokai Pro (Filter Spectrum)",
    "yaml.disableSchemaDetection": [
        "**/.github/workflows/*.yml",
        "**/.github/workflows/*.yaml",
        "**/.gitea/workflows/*.yml",
        "**/.gitea/workflows/*.yaml",
        "**/.forgejo/workflows/*.yml",
        "**/.forgejo/workflows/*.yaml"
    ]
}
