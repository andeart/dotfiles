export ZSH="$HOME/.oh-my-zsh"

# Disable auto-setting terminal title.
DISABLE_AUTO_TITLE="true"

COMPLETION_WAITING_DOTS="%F{109}󰔟%f"

plugins=(git)

# Set $ZSH_CUSTOM to our dotfiles zsh-custom repo before sourcing oh-my-zsh.sh
ZSH_CUSTOM="$(dirname "$(readlink ~/.zshrc)")/zsh-custom"

# Initialize OMZ
source "$ZSH/oh-my-zsh.sh"

# zshrc.local must be sourced before shell integration so that
[ -f ~/.zshrc.local ] && source ~/.zshrc.local

export NVM_DIR="$HOME/.nvm"

# Put the default Node on PATH directly instead of sourcing the ~4000-line
# nvm.sh on every shell. That source costs ~0.3s (over half of total startup)
# just to end up with node/npm on PATH. The glob below picks the highest
# installed version's bin dir (N=nullglob, n=numeric sort), which is what the
# `default` -> `node` alias resolves to, and prepends it.
#
# This keeps real `node`/`npm`/`npx` binaries (not function shims) on PATH, so
# Claude Code's env snapshot replays real binaries for agent Bash calls. An
# earlier lazy-load shim stubbed node/npm/npx/nvm; the snapshot captured those
# stubs without their helper and any agent `node ...` call infinite-recursed
# until FUNCNEST. The stub below covers ONLY `nvm`, never node/npm/npx, and
# unsets itself before re-sourcing, so there is no recursion. Explicit version
# switching (`nvm use 18`) still works on first call.
node_bin=("$NVM_DIR"/versions/node/v*/bin(/Nn))
[ -n "$node_bin" ] && export PATH="${node_bin[-1]}:$PATH"
nvm() { unset -f nvm; \. "$NVM_DIR/nvm.sh"; nvm "$@"; }

source "${BREW_PREFIX}/share/zsh-autosuggestions/zsh-autosuggestions.zsh"

# This loads syntax highlighting.
# This must always be at the very end of this file to process syntax highlighting correctly.
source "${BREW_PREFIX}/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
