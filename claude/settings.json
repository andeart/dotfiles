{
  "env": {
    "CLAUDE_CODE_IDLE_NOTIFICATION_THRESHOLD_MS": "1000"
  },
  "permissions": {
    "allow": [
      "Bash(dotfiles*)",
      "Read(~/.agents/AGENTS.md)",
      "Read(~/.agents/skills/plane-work-item-conventions/CONVENTIONS.md)"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "$HOME/.agents"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; case \"$f\" in *.json) jq . \"$f\" > /dev/null ;; *.yml|*.yaml) yamllint \"$f\" ;; *.md) markdownlint-cli2 --config ~/.markdownlint.yml \"$f\" ;; esac; }"
          }
        ]
      }
    ],
    "PreToolUse": []
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "warp@claude-code-warp": true
  },
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    },
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "effortLevel": "high",
  "preferredNotifChannel": "auto",
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true
}
