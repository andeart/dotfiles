#!/usr/bin/env bash
set -euo pipefail

DOTFILES_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

BOLD='\033[1m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
RESET='\033[0m'

# ---------------------------------------------------------------------------
# Path mapping (repo source → live destinations)
# Each entry: "<repo_relpath>|<live_dest_1>[,<live_dest_2>,...]"
# Leading ~/ in destinations is expanded to $HOME at runtime.
# ---------------------------------------------------------------------------
PATH_MAPPING=(
  "agents/AGENTS.md|~/.agents/AGENTS.md"
  "agents/skills|~/.agents/skills,~/.claude/skills"
  "claude/CLAUDE.md|~/.claude/CLAUDE.md"
  "claude/settings.json|~/.claude/settings.json"
  "claude/statusline-command.sh|~/.claude/statusline-command.sh"
)

DOTFILES_STATE_FILE="${DOTFILES_STATE_FILE:-$HOME/.dotfiles/sync-state.json}"

_expand_tilde() {
  local p="$1"
  printf '%s' "${p/#\~/$HOME}"
}

_sha256_file() {
  local f="$1"
  if [ ! -f "$f" ]; then
    return 0
  fi
  shasum -a 256 "$f" | awk '{print $1}'
}

_manifest_ensure() {
  mkdir -p "$(dirname "$DOTFILES_STATE_FILE")"
  if [ ! -f "$DOTFILES_STATE_FILE" ]; then
    echo '{}' > "$DOTFILES_STATE_FILE"
  fi
}

_manifest_read() {
  local key="$1"
  _manifest_ensure
  jq -r --arg k "$key" '.[$k] // "null"' "$DOTFILES_STATE_FILE"
}

_manifest_write() {
  local key="$1" value="$2"
  _manifest_ensure
  local tmp
  tmp="$(mktemp)"
  trap 'rm -f "$tmp"' EXIT
  jq --arg k "$key" --arg v "$value" '.[$k] = $v' "$DOTFILES_STATE_FILE" > "$tmp"
  mv "$tmp" "$DOTFILES_STATE_FILE"
  trap - EXIT
}

_manifest_delete() {
  local key="$1"
  _manifest_ensure
  local tmp
  tmp="$(mktemp)"
  trap 'rm -f "$tmp"' EXIT
  jq --arg k "$key" 'del(.[$k])' "$DOTFILES_STATE_FILE" > "$tmp"
  mv "$tmp" "$DOTFILES_STATE_FILE"
  trap - EXIT
}

_classify() {
  local repo_path="$1" live_path="$2"
  local repo_hash live_hash manifest_hash
  repo_hash="$(_sha256_file "$repo_path")"
  live_hash="$(_sha256_file "$live_path")"
  manifest_hash="$(_manifest_read "$live_path")"

  local repo_present=0 live_present=0 manifest_present=0
  [ -n "$repo_hash" ] && repo_present=1
  [ -n "$live_hash" ] && live_present=1
  [ "$manifest_hash" != "null" ] && manifest_present=1

  # both_removed is unreachable through the public PATH_MAPPING walker but kept
  # as a defensive fallthrough.
  if [ $repo_present -eq 0 ] && [ $live_present -eq 0 ]; then
    echo "both_removed"
    return
  fi

  if [ $repo_present -eq 1 ] && [ $live_present -eq 0 ]; then
    if [ $manifest_present -eq 1 ]; then echo "live_removed"; else echo "repo_added"; fi
    return
  fi

  if [ $repo_present -eq 0 ] && [ $live_present -eq 1 ]; then
    if [ $manifest_present -eq 1 ]; then echo "repo_removed"; else echo "live_added"; fi
    return
  fi

  # Both present. Decide based on hash comparisons.
  if [ "$repo_hash" = "$live_hash" ] && [ "$repo_hash" = "$manifest_hash" ]; then
    echo "in_sync"; return
  fi
  if [ "$repo_hash" = "$live_hash" ] && [ $manifest_present -eq 0 ]; then
    echo "in_sync"; return  # first-run: repo == live, no manifest yet
  fi

  local repo_changed=0 live_changed=0
  if [ $manifest_present -eq 1 ]; then
    [ "$repo_hash" != "$manifest_hash" ] && repo_changed=1
    [ "$live_hash" != "$manifest_hash" ] && live_changed=1
  else
    # No manifest entry but repo and live differ — treat as both changed
    # (we can't tell which side is canonical without the manifest anchor).
    # The "stale manifest" variant — repo and live are byte-identical but both
    # disagree with the manifest hash — also lands in both_changed via the
    # comparisons above. That's the least-wrong answer until a push or freeze
    # rewrites the manifest.
    repo_changed=1
    live_changed=1
  fi

  if [ $repo_changed -eq 1 ] && [ $live_changed -eq 1 ]; then
    echo "both_changed"
  elif [ $repo_changed -eq 1 ]; then
    echo "repo_changed"
  else
    echo "live_changed"
  fi
}

# Returns 0 and prints lines: "<state>\t<repo_path>\t<live_path>"
# for every (repo_file, live_file) pair across all entries in PATH_MAPPING.
# Recurses into directory mappings; processes each mirror destination
# independently. Honors DOTFILES_ROOT_OVERRIDE / DOTFILES_HOME_OVERRIDE
# / DOTFILES_MAPPING_OVERRIDE for testing.
_walk_mapping() {
  local repo_root="${DOTFILES_ROOT_OVERRIDE:-$DOTFILES_ROOT}"
  local home_root="${DOTFILES_HOME_OVERRIDE:-$HOME}"

  local mapping=()
  if [ -n "${DOTFILES_MAPPING_OVERRIDE:-}" ]; then
    mapping=("$DOTFILES_MAPPING_OVERRIDE")
  else
    mapping=("${PATH_MAPPING[@]}")
  fi

  local entry repo_rel live_dests_csv repo_full live_dest live_full
  for entry in "${mapping[@]}"; do
    repo_rel="${entry%%|*}"
    live_dests_csv="${entry#*|}"
    repo_full="$repo_root/$repo_rel"

    local IFS_save="$IFS"
    IFS=','
    for live_dest in $live_dests_csv; do
      IFS="$IFS_save"
      # Expand ~ relative to home_root (not literal $HOME) so tests can swap
      live_full="${live_dest/#\~/$home_root}"
      _walk_one_pair "$repo_full" "$live_full"
      IFS=','
    done
    IFS="$IFS_save"
  done
}

_walk_one_pair() {
  local repo_path="$1" live_path="$2"

  if [ -d "$repo_path" ] || [ -d "$live_path" ]; then
    # Directory mapping: enumerate the union of files on both sides.
    # Use a temp file to track relative paths seen on the repo side so we can
    # skip them when enumerating the live side (avoids bash 4+ associative arrays).
    local seen_tmp
    seen_tmp="$(mktemp)"
    trap 'rm -f "$seen_tmp"' EXIT
    if [ -d "$repo_path" ]; then
      while IFS= read -r f; do
        local rel="${f#$repo_path/}"
        printf '%s\n' "$rel" >> "$seen_tmp"
        local lp="$live_path/$rel"
        printf "%s\t%s\t%s\n" "$(_classify "$f" "$lp")" "$f" "$lp"
      done < <(find "$repo_path" -type f)
    fi
    if [ -d "$live_path" ]; then
      while IFS= read -r f; do
        local rel="${f#$live_path/}"
        if ! grep -qxF "$rel" "$seen_tmp" 2>/dev/null; then
          local rp="$repo_path/$rel"
          printf "%s\t%s\t%s\n" "$(_classify "$rp" "$f")" "$rp" "$f"
        fi
      done < <(find "$live_path" -type f)
    fi
    rm -f "$seen_tmp"
    trap - EXIT
  else
    # File mapping
    printf "%s\t%s\t%s\n" "$(_classify "$repo_path" "$live_path")" "$repo_path" "$live_path"
  fi
}

# Print a unified diff between the repo and live versions of a both_changed
# path. Used by status/push/freeze/precommit when surfacing conflicts so the
# user can resolve without first running `diff` manually.
# Precondition: callers must only invoke this when both files exist; this is
# guaranteed by the `both_changed` classification, which requires both sides
# to be present and have differing contents.
_print_conflict_diff() {
  local repo_p="$1" live_p="$2"
  echo -e "    ${YELLOW}--- repo: $repo_p${RESET}"
  echo -e "    ${YELLOW}+++ live: $live_p${RESET}"
  diff -u "$repo_p" "$live_p" | sed 's/^/      /' || true
}

usage() {
  echo "Usage: dotfiles <command>"
  echo ""
  echo "Commands:"
  echo "  freeze    Snapshot live state into the repo (vscode, brew, agents)"
  echo "  push      Apply repo state to live ~/.claude and ~/.agents files"
  echo "  status    Show drift between repo and live agent/claude files"
  exit 0
}

# ---------------------------------------------------------------------------
# push / status / freeze_agents (stubs; filled in across Tasks 4-9)
# ---------------------------------------------------------------------------

push() {
  echo -e "${BOLD}push${RESET}  repo -> live"
  echo ""

  # Phase 1: classify everything; collect blockers and writable items.
  local blockers=()
  local conflicts=()
  local writable=()
  local symlink_blockers=()

  local state repo_p live_p
  while IFS=$'\t' read -r state repo_p live_p; do
    if [ -L "$live_p" ]; then
      symlink_blockers+=("$live_p")
      continue
    fi
    case "$state" in
      both_changed)
        blockers+=("$state\t$live_p")
        conflicts+=("$repo_p|$live_p")
        ;;
      live_changed|live_added|live_removed)
        blockers+=("$state\t$live_p")
        ;;
      in_sync)
        ;;
      repo_changed|repo_added|repo_removed)
        writable+=("$state\t$repo_p\t$live_p")
        ;;
    esac
  done < <(_walk_mapping)

  if [ ${#symlink_blockers[@]} -gt 0 ]; then
    echo -e "  ${RED}refusing to overwrite symlink(s):${RESET}"
    local s
    for s in "${symlink_blockers[@]+"${symlink_blockers[@]}"}"; do
      echo "    $s"
    done
    echo ""
    echo -e "  ${YELLOW}delete the symlink manually, then re-run push${RESET}"
    return 2
  fi

  if [ ${#blockers[@]} -gt 0 ]; then
    echo -e "  ${RED}live has changes that haven't been captured:${RESET}"
    local b
    for b in "${blockers[@]+"${blockers[@]}"}"; do
      echo -e "    $b"
    done
    if [ ${#conflicts[@]} -gt 0 ]; then
      echo ""
      echo -e "  ${RED}conflict diffs:${RESET}"
      local pair r_p l_p
      for pair in "${conflicts[@]+"${conflicts[@]}"}"; do
        r_p="${pair%%|*}"
        l_p="${pair#*|}"
        _print_conflict_diff "$r_p" "$l_p"
      done
    fi
    echo ""
    echo -e "  ${YELLOW}run 'dotfiles freeze' first (or resolve conflicts manually)${RESET}"
    return 2
  fi

  # Phase 2: apply.
  local applied=0
  local w
  for w in "${writable[@]+"${writable[@]}"}"; do
    state="$(echo -e "$w" | awk -F'\t' '{print $1}')"
    repo_p="$(echo -e "$w" | awk -F'\t' '{print $2}')"
    live_p="$(echo -e "$w" | awk -F'\t' '{print $3}')"
    case "$state" in
      repo_changed|repo_added)
        mkdir -p "$(dirname "$live_p")"
        cp "$repo_p" "$live_p"
        _manifest_write "$live_p" "$(_sha256_file "$live_p")"
        echo -e "  ${GREEN}wrote${RESET}  $live_p"
        applied=$((applied + 1))
        ;;
      repo_removed)
        rm -f "$live_p"
        _manifest_delete "$live_p"
        echo -e "  ${YELLOW}removed${RESET}  $live_p"
        applied=$((applied + 1))
        ;;
    esac
  done

  echo ""
  if [ $applied -eq 0 ]; then
    echo -e "  ${GREEN}nothing to do - already in sync${RESET}"
  else
    echo -e "  ${GREEN}push complete (${applied} change(s))${RESET}"
  fi
}

status() {
  echo -e "${BOLD}agents/claude sync status${RESET}"
  echo ""

  local found_conflict=0 has_drift=0
  local conflicts=()
  local state repo_p live_p
  while IFS=$'\t' read -r state repo_p live_p; do
    case "$state" in
      in_sync)
        echo -e "  ${GREEN}${state}${RESET}  $live_p"
        ;;
      both_changed)
        echo -e "  ${RED}${state}${RESET}  $live_p"
        conflicts+=("$repo_p|$live_p")
        found_conflict=1
        has_drift=1
        ;;
      *)
        echo -e "  ${YELLOW}${state}${RESET}  $live_p"
        has_drift=1
        ;;
    esac
  done < <(_walk_mapping)

  if [ ${#conflicts[@]} -gt 0 ]; then
    echo ""
    echo -e "  ${RED}conflict diffs:${RESET}"
    local pair r_p l_p
    for pair in "${conflicts[@]}"; do
      r_p="${pair%%|*}"
      l_p="${pair#*|}"
      _print_conflict_diff "$r_p" "$l_p"
    done
  fi

  echo ""
  if [ $found_conflict -eq 1 ]; then
    echo -e "  ${RED}conflicts present - resolve manually before running push or freeze${RESET}"
    return 2
  elif [ $has_drift -eq 1 ]; then
    echo -e "  ${YELLOW}drift present - run 'dotfiles push' or 'dotfiles freeze' to reconcile${RESET}"
    return 0
  else
    echo -e "  ${GREEN}clean${RESET}"
    return 0
  fi
}

freeze_agents() {
  echo "freeze_agents: not implemented yet"
}

# ---------------------------------------------------------------------------
# freeze
# ---------------------------------------------------------------------------

freeze_vscode() {
  echo -e "${BOLD}VS Code extensions${RESET}"

  if ! command -v code &>/dev/null; then
    echo -e "  ${RED}skipped${RESET} - 'code' CLI not found"
    return
  fi

  local ext_file="$DOTFILES_ROOT/vscode/extensions.txt"
  local live
  live=$(code --list-extensions | sort)
  local committed
  committed=$(sort "$ext_file")

  if [[ "$live" == "$committed" ]]; then
    echo -e "  ${GREEN}up to date${RESET}"
    return
  fi

  local added removed
  added=$(comm -23 <(echo "$live") <(echo "$committed"))
  removed=$(comm -13 <(echo "$live") <(echo "$committed"))

  if [[ -n "$added" ]]; then
    echo -e "  ${GREEN}added:${RESET}"
    while IFS= read -r ext; do
      echo "    + $ext"
    done <<< "$added"
  fi

  if [[ -n "$removed" ]]; then
    echo -e "  ${YELLOW}removed:${RESET}"
    while IFS= read -r ext; do
      echo "    - $ext"
    done <<< "$removed"
  fi

  echo "$live" > "$ext_file"
  echo -e "  ${GREEN}updated${RESET} vscode/extensions.txt"
}

freeze_brew() {
  echo -e "${BOLD}Homebrew packages${RESET}"

  if ! command -v brew &>/dev/null; then
    echo -e "  ${RED}skipped${RESET} - brew not found"
    return
  fi

  local brewfile="$DOTFILES_ROOT/brew/Brewfile"

  # Collect what's declared in the Brewfile (strip comments and blank lines)
  local declared_brew declared_cask
  declared_brew=$(grep -E '^brew ' "$brewfile" | sed 's/brew "//;s/"//' | sort)
  declared_cask=$(grep -E '^cask ' "$brewfile" | sed 's/cask "//;s/"//' | sort)

  # Collect what's actually installed (leaf packages only - no auto-installed deps)
  local installed_brew installed_cask
  installed_brew=$(brew leaves | sort)
  installed_cask=$(brew list --cask 2>/dev/null | sort)

  local missing_brew extra_brew missing_cask extra_cask
  missing_brew=$(comm -23 <(echo "$declared_brew") <(echo "$installed_brew"))
  extra_brew=$(comm -13 <(echo "$declared_brew") <(echo "$installed_brew"))
  missing_cask=$(comm -23 <(echo "$declared_cask") <(echo "$installed_cask"))
  extra_cask=$(comm -13 <(echo "$declared_cask") <(echo "$installed_cask"))

  if [[ -z "$missing_brew" && -z "$extra_brew" && -z "$missing_cask" && -z "$extra_cask" ]]; then
    echo -e "  ${GREEN}up to date${RESET}"
    return
  fi

  if [[ -n "$extra_brew" ]]; then
    echo -e "  ${GREEN}installed but not in Brewfile (brew):${RESET}"
    while IFS= read -r pkg; do
      echo "    + $pkg"
    done <<< "$extra_brew"
  fi

  if [[ -n "$extra_cask" ]]; then
    echo -e "  ${GREEN}installed but not in Brewfile (cask):${RESET}"
    while IFS= read -r pkg; do
      echo "    + $pkg"
    done <<< "$extra_cask"
  fi

  if [[ -n "$missing_brew" ]]; then
    echo -e "  ${YELLOW}in Brewfile but not installed (brew):${RESET}"
    while IFS= read -r pkg; do
      echo "    - $pkg"
    done <<< "$missing_brew"
  fi

  if [[ -n "$missing_cask" ]]; then
    echo -e "  ${YELLOW}in Brewfile but not installed (cask):${RESET}"
    while IFS= read -r pkg; do
      echo "    - $pkg"
    done <<< "$missing_cask"
  fi

  echo ""
  echo -e "  ${YELLOW}Brewfile is manually curated - edit brew/Brewfile to reconcile.${RESET}"
}

freeze() {
  echo ""
  freeze_vscode
  echo ""
  freeze_brew
  echo ""
  freeze_agents
  echo ""
}

# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------

if [ -z "${_DOTFILES_LIB_ONLY:-}" ]; then
  case "${1:-}" in
    freeze)         shift; freeze "$@" ;;
    push)           shift; push "$@" ;;
    status)         shift; status "$@" ;;
    -h|--help|"")   usage ;;
    *)
      echo "Unknown command: $1" >&2
      usage
      ;;
  esac
fi
