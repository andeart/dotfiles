#!/usr/bin/env bash
# Test harness: sources bin/dotfiles in library mode and exposes its internal
# helpers under documented subcommands. NOT installed on PATH; only invoked
# from tests/.
set -euo pipefail

DOTFILES_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
_DOTFILES_LIB_ONLY=1
# shellcheck source=./dotfiles
source "$DOTFILES_ROOT/bin/dotfiles"

case "${1:-}" in
  sha256)         _sha256_file "${2:?usage: dotfiles_test sha256 <file>}" ;;
  manifest_read)  _manifest_read "${2:?usage: dotfiles_test manifest_read <live_path>}" ;;
  manifest_write) _manifest_write "${2:?usage: dotfiles_test manifest_write <live_path> <hash>}" "${3:?usage: dotfiles_test manifest_write <live_path> <hash>}" ;;
  manifest_delete) _manifest_delete "${2:?usage: dotfiles_test manifest_delete <live_path>}" ;;
  classify)       _classify "${2:?usage: dotfiles_test classify <repo_path> <live_path>}" "${3:?usage: dotfiles_test classify <repo_path> <live_path>}" ;;
  walk)           _walk_mapping ;;
  freeze_agents)  freeze_agents ;;
  *)              echo "Unknown test command: ${1:-<none>}" >&2; exit 1 ;;
esac
