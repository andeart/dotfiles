{
    "cSpell.blockCheckingWhenLineLengthGreaterThan": 20000,
    "cSpell.blockCheckingWhenTextChunkSizeGreaterThan": 1000,
    "cSpell.diagnosticLevel": "Warning",
    "cSpell.spellCheckOnlyWorkspaceFiles": true,
    "cSpell.userWords": [
        "Anurag",
        "anuragdevanapally",
        "automations",
        "cupertino",
        "Devanapally",
        "hacsfiles",
        "homeassistant",
        "mwba",
        "optimised",
        "organisation",
        "organised",
        "protoc",
        "protos",
        "pubspec",
        "rgba",
        "summarise",
        "Symbolication",
        "venv",
        "xcodeproj",
        "xcworkspace"
    ],
    "cursor.cpp.disabledLanguages": [
        "scminput"
    ],
    "[dart]": {
        "editor.formatOnSave": true,
        "editor.formatOnType": true,
        "editor.rulers": [
            100
        ],
        "editor.selectionHighlight": false,
        "editor.tabCompletion": "onlySnippets",
        "editor.wordBasedSuggestions": "off"
    },
    "dart.cliConsole": "terminal",
    "dart.closingLabelsTextStyle": "italic",
    "dart.debugExternalPackageLibraries": true,
    "dart.debugSdkLibraries": true,
    "dart.flutterSelectDeviceWhenConnected": false,
    "dart.flutterHotReloadOnSave": "manualIfDirty",
    "dart.previewFlutterUiGuides": true,
    "dart.promptToGetPackages": false,
    "dart.renameFilesWithClasses": "always",
    "dart.runPubGetOnPubspecChanges": "never",
    "dart.showTodos": false,
    "debug.internalConsoleOptions": "openOnSessionStart",
    "debug.toolBarLocation": "commandCenter",
    "editor.codeActionsOnSave": {},
    "editor.guides.bracketPairs": true,
    "editor.hover.delay": 1000,
    "editor.renderWhitespace": "all",
    "editor.wordWrap": "on",
    "editor.wordWrapColumn": 100,
    "explorer.openEditors.sortOrder": "alphabetical",
    "explorer.openEditors.visible": 100,
    "files.exclude": {
        "**/.git": false,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/flutter/ephemeral": true,
        "**/Flutter/ephemeral": true,
        "**/.symlinks": false,
        "**/.plugin_symlinks": true
    },
    "git.openRepositoryInParentFolders": "never",
    "go.toolsManagement.autoUpdate": true,
    "[markdown]": {
        "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
    },
    "markdown.occurrencesHighlight.enabled": true,
    "references.preferredLocation": "view",
    "redhat.telemetry.enabled": false,
    "testing.automaticallyOpenPeekView": "failureAnywhere",
    "window.commandCenter": true,
    "window.openFoldersInNewWindow": "on",
    "window.title": "${rootName}${separator}${profileName}${separator}${activeEditorShort}",
    "window.zoomLevel": 1.5,
    "workbench.colorTheme": "GitHub Dark Default",
    "workbench.editor.limit.value": 100,
    "workbench.editor.showTabs": "none",
    "workbench.iconTheme": "symbols",
    "cursor.composer.shouldChimeAfterChatFinishes": true,
    "color-highlight.matchRgbWithNoFunction": true,
    "color-highlight.matchWords": true,
    "security.workspace.trust.untrustedFiles": "open"
}
