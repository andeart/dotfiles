#!/usr/bin/env bash
# Interactive branch deleter with gum.
# Usage: git bd
set -euo pipefail

BOLD=$'\033[1m'
CYAN=$'\033[1;36m'
BLUE=$'\033[1;34m'
MAGENTA=$'\033[1;35m'
RED=$'\033[1;31m'
INVERT=$'\033[7m'
DIM=$'\033[2m'
ITALIC=$'\033[3m'
RESET=$'\033[0m'

current_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo "")

# ─── main loop ────────────────────────────────────────────────────────────────
while true; do
  i=0
  branches=()
  display_lines=()

  while IFS=$'\t' read -r branch author; do
    [[ -z "$branch" ]] && continue
    branches+=("$branch")

    if [[ "$current_branch" == "$branch" ]]; then
      branch_colored="${CYAN}${INVERT} ${branch} ${RESET}"
    else
      branch_colored="${CYAN}${branch}${RESET}"
    fi

    commit_info=$(git log -1 --pretty=format:"%cd%x09%s" --date=format-local:'%Y-%m-%d %H:%M' "$branch" --)
    date_part="${commit_info%%	*}"
    subject="${commit_info#*	}"

    display_lines+=("${i}. ${branch_colored} ${BLUE}${date_part}${RESET} ${subject} ${MAGENTA}-${author}${RESET}")
    ((i++))
  done < <(git for-each-ref --sort=-committerdate --format='%(refname:short)%09%(authorname)' refs/heads/)

  if [[ ${#branches[@]} -eq 0 ]]; then
    echo "No local branches found."
    exit 0
  fi

  if [[ ${#branches[@]} -eq 1 && "$current_branch" == "${branches[0]}" ]]; then
    echo "Only the current branch (${CYAN}${current_branch}${RESET}) remains."
    git maintenance run --auto 2>/dev/null
    git gc --prune=now --quiet
    echo "${DIM}Collected garbage.${RESET}"
    exit 0
  fi

  # ─── select ─────────────────────────────────────────────────────────────────
  selection=$(printf '%s\n' "${display_lines[@]}" \
    "${BOLD}∅ ${RED}Collect garbage${RESET}" \
    "${BOLD}✕ ${RED}Cancel${RESET}" \
    | gum choose --no-strip-ansi --height 20 --cursor "❯ " || true)

  if [[ -z "$selection" || "$selection" == *"Cancel"* ]]; then
    echo "Cancelled."
    exit 0
  fi

  if [[ "$selection" == *"Collect garbage"* ]]; then
    git maintenance run --auto 2>/dev/null
    git gc --prune=now --quiet
    echo "${DIM}Collected garbage.${RESET}"
    exit 0
  fi

  # ─── find selected branch ──────────────────────────────────────────────────
  selected_index="${selection%%.*}"

  if [[ ! "$selected_index" =~ ^[0-9]+$ ]] || [[ $selected_index -ge ${#branches[@]} ]]; then
    echo "Invalid selection."
    continue
  fi

  branch_to_delete="${branches[$selected_index]}"

  if [[ "$current_branch" == "$branch_to_delete" ]]; then
    echo "Cannot delete the current branch ${CYAN}${branch_to_delete}${RESET}."
    continue
  fi

  # ─── delete ─────────────────────────────────────────────────────────────────
  if git branch -d "$branch_to_delete" 2>/dev/null; then
    echo "Deleted ${CYAN}${branch_to_delete}${RESET}."
  else
    if gum confirm "Not fully merged. Force delete ${CYAN}${branch_to_delete}${RESET}?"; then
      git branch -D "$branch_to_delete"
      echo "Force deleted ${CYAN}${branch_to_delete}${RESET}."
    else
      echo "Skipped ${CYAN}${branch_to_delete}${RESET}."
      continue
    fi
  fi

  printf '%s' "$branch_to_delete" | pbcopy
  echo "${DIM}${ITALIC}Branch name copied to clipboard.${RESET}"
  echo ""
done
