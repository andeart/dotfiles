#!/usr/bin/env bash
# Pick up unpushed commits from the current branch (e.g. main), move them to a
# new worktree branch, push, create a PR, then clean up and reset the original
# branch to its remote state.
# Usage: git wt-pickup [--base <branch>] [--dir <path>] [--name <branch>]
set -euo pipefail

BOLD=$'\033[1m'
CYAN=$'\033[1;36m'
BLUE=$'\033[1;34m'
RED=$'\033[1;31m'
DIM=$'\033[2m'
ITALIC=$'\033[3m'
RESET=$'\033[0m'

# ─── word lists (shared with wt-start) ───────────────────────────────────────
adjectives=(
  bold    brave   bright  calm    clean   clear   cool    deep
  dry     fair    fast    firm    flat    free    fresh   full
  great   hard    high    keen    kind    lean    light   long
  neat    new     noble   old     open    pure    quiet   raw
  rich    safe    sharp   slim    smart   soft    still   strong
  swift   thin    true    vast    warm    wide    wild    wise
  young   dark    fine    late
)
nouns=(
  arch    arrow   birch   blade   bluff   brook   cedar   cliff
  cloud   coral   cove    crest   dawn    dune    ember   falcon
  fern    field   flame   forest  gate    glade   grove   harbor
  knoll   lake    maple   marsh   meadow  mesa    oak     pass
  peak    pine    plain   pond    reef    ridge   river   shore
  spark   stone   storm   tide    torch   trail   vale    willow
  shield  frost   mist    north
)
charset='0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ'

# ─── argument parsing ──────────────────────────────────────────────────────────
base_branch=""
custom_dir=""
custom_name=""

usage() {
  echo "usage: git wt-pickup [--base <branch>] [--dir <path>] [--name <branch>]" >&2
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --base)
      [[ $# -lt 2 ]] && { echo "error: --base requires a value" >&2; usage; exit 1; }
      base_branch="$2"; shift 2 ;;
    --dir)
      [[ $# -lt 2 ]] && { echo "error: --dir requires a value" >&2; usage; exit 1; }
      custom_dir="$2"; shift 2 ;;
    --name)
      [[ $# -lt 2 ]] && { echo "error: --name requires a value" >&2; usage; exit 1; }
      custom_name="$2"; shift 2 ;;
    --*)
      echo "error: unknown option: $1" >&2; usage; exit 1 ;;
    *)
      echo "error: unexpected argument: $1" >&2; usage; exit 1 ;;
  esac
done

# ─── prerequisites ────────────────────────────────────────────────────────────
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo "error: not inside a git repository." >&2
  exit 1
fi

if ! command -v gh &>/dev/null; then
  echo "error: 'gh' (GitHub CLI) is required for PR creation." >&2
  exit 1
fi

repo_root="$(git rev-parse --show-toplevel)"

# ─── must be on the main working tree ─────────────────────────────────────────
current_dir="$(pwd -P)"
first_wt=true
while IFS= read -r line; do
  if [[ "$line" =~ ^worktree\ (.+)$ ]]; then
    wt_path="${BASH_REMATCH[1]}"
    wt_path="$(cd "$wt_path" && pwd -P 2>/dev/null || echo "$wt_path")"
    if [[ "$first_wt" == true ]]; then
      main_wt_path="$wt_path"
      first_wt=false
    elif [[ "$current_dir" == "$wt_path" || "$current_dir" == "$wt_path/"* ]]; then
      echo "error: git wt-pickup must be run from the main working tree, not from inside a worktree." >&2
      exit 1
    fi
  fi
done < <(git worktree list --porcelain)

# ─── resolve base branch ──────────────────────────────────────────────────────
if [[ -z "$base_branch" ]]; then
  if git rev-parse --verify main &>/dev/null; then
    base_branch="main"
  elif git rev-parse --verify master &>/dev/null; then
    base_branch="master"
  else
    echo "error: no 'main' or 'master' branch found. Specify one with --base <branch>." >&2
    exit 1
  fi
else
  if ! git rev-parse --verify "$base_branch" &>/dev/null; then
    echo "error: branch '$base_branch' does not exist." >&2
    exit 1
  fi
fi

current_branch="$(git symbolic-ref --short HEAD)"

# ─── safety gate: clean working tree ──────────────────────────────────────────
dirty="$(git status --porcelain 2>/dev/null)"
if [[ -n "$dirty" ]]; then
  echo "error: working tree has uncommitted changes:" >&2
  git status --short >&2
  printf "\nCommit or stash your work, then re-run.\n" >&2
  exit 1
fi

# ─── detect unpushed commits ──────────────────────────────────────────────────
if ! git rev-parse --verify '@{upstream}' &>/dev/null; then
  echo "error: current branch '${current_branch}' has no upstream. Cannot determine new commits." >&2
  exit 1
fi

commits="$(git log '@{upstream}..HEAD' --oneline)"
if [[ -z "$commits" ]]; then
  echo "No unpushed commits on ${CYAN}${current_branch}${RESET}. Nothing to pick up."
  exit 0
fi

commit_count="$(echo "$commits" | wc -l | tr -d ' ')"
reset_target="$(git rev-parse '@{upstream}')"

echo "Found ${BOLD}${commit_count}${RESET} unpushed commit(s) on ${CYAN}${current_branch}${RESET}:"
echo "${DIM}${commits}${RESET}"
echo ""

# ─── generate branch name (wt-start flow) ─────────────────────────────────────
if [[ -n "$custom_name" ]]; then
  branch_name="$custom_name"
else
  adj="${adjectives[$((RANDOM % ${#adjectives[@]}))]}"
  noun="${nouns[$((RANDOM % ${#nouns[@]}))]}"
  c1="${charset:$((RANDOM % 36)):1}"
  c2="${charset:$((RANDOM % 36)):1}"
  branch_name="${adj}-${noun}-${c1}${c2}"

  printf "Generated branch name: ${CYAN}%s${RESET}\nProceed? [y/n] " "$branch_name"
  read -r answer
  case "$answer" in
    y|Y) ;;
    *) echo "Aborted. Re-run to generate a new name."; exit 0 ;;
  esac
fi

# ─── validate branch doesn't exist ────────────────────────────────────────────
if git rev-parse --verify "$branch_name" &>/dev/null; then
  echo "error: '$branch_name' already exists as a branch or tag." >&2
  exit 1
fi

# ─── resolve worktree path ────────────────────────────────────────────────────
if [[ -n "$custom_dir" ]]; then
  worktree_path="$custom_dir"
else
  repo_parent="$(dirname "$repo_root")"
  repo_name="$(basename "$repo_root")"
  sibling_dir="${repo_parent}/${repo_name}-worktrees"
  worktree_path="${sibling_dir}/${branch_name}"

  if [[ ! -d "$sibling_dir" ]]; then
    printf "Directory '%s' does not exist. Create it? [y/n] " "$sibling_dir"
    read -r answer
    case "$answer" in
      y|Y) ;;
      *) echo "Aborted."; exit 0 ;;
    esac
  fi
fi

# ─── create worktree at the upstream point (before our commits) ───────────────
echo ""
echo "Creating worktree..."
mkdir -p "$(dirname "$worktree_path")"
if ! git worktree add -b "$branch_name" "$worktree_path" "$reset_target"; then
  echo "error: failed to create worktree." >&2
  exit 1
fi

# ─── cherry-pick the commits onto the new branch ─────────────────────────────
echo "Moving commits to ${CYAN}${branch_name}${RESET}..."
commit_range="${reset_target}..${current_branch}"
if ! git -C "$worktree_path" cherry-pick "$commit_range"; then
  echo "error: cherry-pick failed. Resolve conflicts in ${worktree_path} and finish manually." >&2
  echo "The worktree and branch have been left in place for you to fix." >&2
  exit 1
fi

# ─── push the new branch ─────────────────────────────────────────────────────
echo "Pushing ${CYAN}${branch_name}${RESET}..."
if ! git -C "$worktree_path" push -u origin "$branch_name"; then
  echo "error: push failed. The worktree and branch have been left in place." >&2
  exit 1
fi

# ─── create PR ────────────────────────────────────────────────────────────────
echo "Creating pull request..."
pr_url="$(cd "$worktree_path" && gh pr create --head "$branch_name" --fill)"
if [[ -z "$pr_url" ]]; then
  echo "error: PR creation failed. Branch has been pushed - create the PR manually." >&2
  exit 1
fi

# ─── clean up: remove worktree ────────────────────────────────────────────────
echo "Removing worktree..."
if ! git worktree remove "$worktree_path"; then
  echo "error: failed to remove worktree at ${worktree_path}. Remove it manually." >&2
  exit 1
fi

# ─── clean up: delete local branch ───────────────────────────────────────────
# The branch is pushed and has a PR - force delete is safe here.
if ! git branch -D "$branch_name" 2>/dev/null; then
  echo "warning: could not delete local branch '${branch_name}'." >&2
fi

# ─── reset the current branch to its remote state ────────────────────────────
echo "Resetting ${CYAN}${current_branch}${RESET} to ${DIM}${reset_target:0:10}${RESET}..."
if ! git reset --hard "$reset_target"; then
  echo "error: failed to reset ${current_branch}. Your commits are safe on ${branch_name}." >&2
  exit 1
fi

# ─── summary ──────────────────────────────────────────────────────────────────
echo ""
echo "Done. ${BOLD}${commit_count}${RESET} commit(s) moved to ${CYAN}${branch_name}${RESET}."
echo "PR created: ${pr_url}"
echo "${CYAN}${current_branch}${RESET} has been reset to its remote state."
printf '%s' "$pr_url" | pbcopy
echo "${DIM}${ITALIC}PR URL copied to clipboard.${RESET}"
