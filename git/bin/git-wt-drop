#!/usr/bin/env bash
# Interactively pick a git worktree and remove it (worktree + branch).
# Usage: git wt-drop
set -euo pipefail

BOLD=$'\033[1m'
CYAN=$'\033[1;36m'
BLUE=$'\033[1;34m'
RED=$'\033[1;31m'
DIM=$'\033[2m'
RESET=$'\033[0m'

# ─── git repo check ────────────────────────────────────────────────────────────
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo "error: not inside a git repository." >&2
  exit 1
fi

# ─── resolve default branch ──────────────────────────────────────────────────
if git rev-parse --verify main &>/dev/null; then
  base_branch="main"
elif git rev-parse --verify master &>/dev/null; then
  base_branch="master"
else
  base_branch=""
fi

# ─── collect worktrees (excluding the main working tree) ──────────────────────
branches=()
wt_paths=()
shas=()
dates=()

first_wt=true
current_wt=""
current_branch_ref=""
while IFS= read -r line; do
  if [[ "$line" =~ ^worktree\ (.+)$ ]]; then
    current_wt="${BASH_REMATCH[1]}"
    current_branch_ref=""
  elif [[ "$line" =~ ^branch\ refs/heads/(.+)$ ]]; then
    current_branch_ref="${BASH_REMATCH[1]}"
  elif [[ -z "$line" ]]; then
    if [[ "$first_wt" == true ]]; then
      first_wt=false
    elif [[ -n "$current_branch_ref" ]]; then
      branches+=("$current_branch_ref")
      wt_paths+=("$current_wt")
      info="$(git log -1 --pretty=format:'%h%x09%cd' \
        --date=format-local:'%Y-%m-%d %H:%M' "$current_branch_ref" -- 2>/dev/null || true)"
      IFS=$'\t' read -r sha date <<< "$info" || true
      shas+=("${sha:-}")
      dates+=("${date:-}")
    fi
    current_wt=""
    current_branch_ref=""
  fi
done < <(git worktree list --porcelain; echo "")

if [[ ${#branches[@]} -eq 0 ]]; then
  echo "No worktrees."
  exit 0
fi

# ─── interactive picker ───────────────────────────────────────────────────────
options_count=${#branches[@]}
total_choices=$((options_count + 1))          # last index = Cancel
selected=0
picker_lines=$((options_count * 4 + 1))        # 4 lines per block + 1 Cancel line
drawn=false
key=""
rest=""

old_stty="$(stty -g </dev/tty)"

restore_term() {
  stty "$old_stty" </dev/tty 2>/dev/null || true
  printf '\033[?25h' >&2
}
on_interrupt() {
  restore_term
  echo ""
  echo "Cancelled."
  exit 130
}
trap restore_term EXIT
trap on_interrupt INT TERM

stty -echo -icanon </dev/tty
printf '\033[?25l' >&2

draw() {
  local i p
  [[ "$drawn" == true ]] && printf '\033[%dA' "$picker_lines" >&2
  drawn=true
  for ((i = 0; i < options_count; i++)); do
    p="${wt_paths[$i]}"
    if [[ "$p" == "$HOME" ]]; then
      p="~"
    elif [[ "$p" == "$HOME"/* ]]; then
      p="~${p#"$HOME"}"
    fi
    if [[ $i -eq $selected ]]; then
      printf '\033[2K%s\n' "${CYAN}❯ ${branches[$i]}${RESET}" >&2
    else
      printf '\033[2K%s\n' "  ${CYAN}${branches[$i]}${RESET}" >&2
    fi
    printf '\033[2K%s\n' "  ${DIM}${shas[$i]}${RESET}  ${BLUE}${dates[$i]}${RESET}" >&2
    printf '\033[2K%s\n' "  ${DIM}${p}${RESET}" >&2
    printf '\033[2K\n' >&2
  done
  if [[ $selected -eq $options_count ]]; then
    printf '\033[2K%s\n' "${CYAN}❯ ${RESET}${BOLD}✕ ${RED}Cancel${RESET}" >&2
  else
    printf '\033[2K%s\n' "  ${BOLD}✕ ${RED}Cancel${RESET}" >&2
  fi
}

while true; do
  draw
  if ! IFS= read -rsn1 key </dev/tty; then
    selected=$options_count
    break
  fi
  case "$key" in
    $'\033')
      # Read the rest of an escape sequence (arrow keys). The timeout must be
      # an integer: macOS ships bash 3.2, whose `read` rejects fractional -t
      # values. -n2 returns the instant both bytes arrive, so arrows stay
      # snappy; the 1s only elapses on a bare Escape press.
      IFS= read -rsn2 -t 1 rest </dev/tty 2>/dev/null || rest=""
      case "$rest" in
        '[A') selected=$(((selected - 1 + total_choices) % total_choices)) ;;
        '[B') selected=$(((selected + 1) % total_choices)) ;;
        *)    selected=$options_count; break ;;
      esac ;;
    '')    break ;;
    k|K)   selected=$(((selected - 1 + total_choices) % total_choices)) ;;
    j|J)   selected=$(((selected + 1) % total_choices)) ;;
    q|Q)   selected=$options_count; break ;;
    *)     ;;
  esac
done

restore_term
trap - EXIT INT TERM
echo "" >&2

# ─── handle Cancel ────────────────────────────────────────────────────────────
if [[ $selected -eq $options_count ]]; then
  echo "Cancelled."
  exit 0
fi

branch_name="${branches[$selected]}"
worktree_path="${wt_paths[$selected]}"

# ─── guard: not the worktree we're standing in ────────────────────────────────
current_dir="$(pwd -P)"
resolved_wt="$worktree_path"
if cd "$worktree_path" 2>/dev/null; then
  resolved_wt="$(pwd -P)"
  cd "$current_dir" || true
fi
if [[ "$current_dir" == "$resolved_wt" || "$current_dir" == "$resolved_wt"/* ]]; then
  echo "error: cannot remove the worktree you are currently inside." >&2
  echo "cd into the main working tree and re-run." >&2
  exit 1
fi

# ─── safety gate: uncommitted changes ─────────────────────────────────────────
dirty="$(git -C "$worktree_path" status --porcelain 2>/dev/null)"
if [[ -n "$dirty" ]]; then
  echo "error: ${CYAN}${branch_name}${RESET} has uncommitted changes:" >&2
  git -C "$worktree_path" status --short >&2
  printf "\nCommit or stash your work, then re-run.\n" >&2
  exit 1
fi

# ─── safety gate: unpushed commits ────────────────────────────────────────────
has_unpushed=false
no_upstream=false
if ! unpushed="$(git -C "$worktree_path" log '@{upstream}..' --oneline 2>/dev/null)"; then
  no_upstream=true
  has_unpushed=true
elif [[ -n "$unpushed" ]]; then
  has_unpushed=true
fi

if [[ "$has_unpushed" == true ]]; then
  if [[ "$no_upstream" == true ]]; then
    echo "${BOLD}${branch_name}${RESET} has no upstream branch."
    if [[ -n "$base_branch" ]]; then
      local_commits="$(git -C "$worktree_path" log --oneline "$base_branch.." 2>/dev/null || true)"
      if [[ -n "$local_commits" ]]; then
        echo "${DIM}Local commits:${RESET}"
        echo "$local_commits"
      fi
    fi
  else
    echo "${BOLD}${branch_name}${RESET} has unpushed commits:"
    echo "$unpushed"
  fi
  echo ""
  choice="$(gum choose --cursor "❯ " \
    "Push and continue" \
    "Continue without pushing (local commits will be lost)" \
    "Cancel" || true)"
  case "$choice" in
    "Push and continue")
      git -C "$worktree_path" push -u origin "$branch_name" ;;
    "Continue without pushing"*)
      ;;
    *)
      echo "Cancelled."
      exit 0 ;;
  esac
fi

# ─── remove worktree and branch ───────────────────────────────────────────────
git worktree remove "$worktree_path"

if ! git branch -d "$branch_name" 2>/dev/null; then
  if gum confirm "Not fully merged. Force delete ${CYAN}${branch_name}${RESET}?"; then
    git branch -D "$branch_name"
  else
    echo "Worktree removed but branch ${CYAN}${branch_name}${RESET} kept."
    exit 0
  fi
fi

echo "Worktree removed. Branch ${CYAN}${branch_name}${RESET} deleted."
