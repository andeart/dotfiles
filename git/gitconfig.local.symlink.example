# Sign details
[user]
    email = AUTHOREMAIL
    name = AUTHORNAME
    # GPG key fingerprint (full 40-char) whose UID matches the email above.
    # Find it with: gpg --list-secret-keys --keyid-format=long
    signingkey = GPGSIGNINGKEY

# GPG-sign commits
[commit]
    gpgsign = true

# Editor
[core]
    editor = code --wait
[diff]
    tool = vscode
[difftool "vscode"]
    cmd = code --wait --diff $LOCAL $REMOTE
[merge]
    tool = vscode
[mergetool "vscode"]
    cmd = code --wait --merge $REMOTE $LOCAL $BASE $MERGED
