# Local/private config goes in the include
[include]
    path = ~/.gitconfig.local

[init]
    defaultBranch = main
[push]
    autoSetupRemote = true
[pull]
    rebase = false

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[color "diff"]
	meta = bold cyan
	frag = cyan
	new = bold green	
	newMoved = bold green
	old = bold red
	oldMoved = bold red
	context = dim
[color "status"]
	added = bold green
	updated = bold green
	changed = yellow
	untracked = bold green
	branch = cyan
	localBranch = cyan
	remoteBranch = cyan
	unmerged = red

[alias]
    aliases = config --get-regexp alias
    amend = commit --amend --no-edit
    br = branch --format=\"%(color:bold red)%(HEAD)%(color:reset) %(color:yellow)%(refname:short)%(color:reset) %(color:cyan)%(committerdate:relative)%(color:reset) %(subject) %(color:bold magenta)-%(authorname)\" --sort=-committerdate
    dff = !git --no-pager diff
    fa = !git fetch --all --prune && git fetch --tags --force
    # TODO: Consolidate hst and lg into a single alias that can take an optional arg for number of commits to show.
    hst = "!f() { \
        if [ -z \"$1\" ]; then \
            lines=\"\"; \
        else \
            lines=\"-$1\"; \
        fi; \
        git log --pretty=tformat:\"%C(yellow)%h%Creset %C(cyan)%cd%C(auto)%d%Creset %s %C(bold magenta)-%an\" --date=format-local:'%Y-%m-%d %H:%M:%S' --abbrev-commit $lines; \
        }; f"
    lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
    st = status -u
    sw = switch
    swc = switch -c
    swo = "!f() { \
        git fetch --all --prune && \
        git fetch --tags --force && \
        git switch \"$1\" && \
        git pull origin && \
        git status; \
        }; f"
    undo = reset --mixed HEAD~1
